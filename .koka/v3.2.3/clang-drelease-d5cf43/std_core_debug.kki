pub fip fun assert[84,13,84,18] : (message : std/core/types/string, condition : std/core/types/bool, ?kk-file-line : std/core/types/string) -> ();
// Explicitly trigger a breakpoint
pub fip fun breakpoint[89,16,89,25] : () -> <(std/core/types/ndet :: X)> ();
 
