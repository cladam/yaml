pub fip fun trace-any[68,13,68,21] : forall<a> (message : std/core/types/string, x : a) -> ();
// Disable tracing completely.
pub fun notrace[73,18,73,24] : () -> <(std/core/types/st :: H -> E)<(std/core/types/global :: H)>> ();
fun unsafe-abort[77,17,77,28] : forall<a> (msg : std/core/types/string) -> a;
